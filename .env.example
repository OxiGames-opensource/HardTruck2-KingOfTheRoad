# Project environment
PROJECT_NAME=hardtruck2-kingoftheroad

# Docker user
APP_UID=1000
APP_GID=1000
# Set to your local user name if needed
APP_USER=app

# Docker Compose app name parent of all projects
APP_PROJECT_NAME=hardtruck2-kingoftheroad

# Docker Compose project name. Keep it unique per project if several projects run in parallel.
COMPOSE_PROJECT_NAME=hardtruck2-kingoftheroad

# Shared Docker network for optional cross-project communication.
SHARED_NETWORK_NAME=hardtruck2-kingoftheroad-shared

# When enabled, ops/docker/up.sh checks and creates the shared network automatically.
AUTO_CREATE_SHARED_NETWORK=0

# Project directory
WORK_DIR=hardtruck2-kingoftheroad
