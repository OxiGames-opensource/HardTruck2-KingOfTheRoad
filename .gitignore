# Project ignores

# Runtime/cache/logs
*.log
.cache/
tmp/
var/

# OS/editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Local configs
.env
.env.local
.env.*.local

# Game / proprietary files
*.exe
*.dll
*.avi
*.bik
*.mp3
*.wav
*.ogg
*.res
*.bne
*.dat
*.pak

# Archives / installers
*.zip
*.7z
*.rar
*.iso
*.bin
*.cue

# Steam / Proton / Wine
compatdata/
pfx/
drive_c/
steamapps/
*.acf

# Python
__pycache__/
*.pyc
.venv/
venv/

# Ghidra local project files
app/ghidra/project/*
!app/ghidra/project/.gitkeep
!app/ghidra/project/README.md

# Ghidra workspace files
app/ghidra/workspace/*
!app/ghidra/workspace/.gitkeep
!app/ghidra/workspace/README.md

# Ghidra script runtime results
app/ghidra/scripts/modules/*/result/*
!app/ghidra/scripts/modules/*/result/.gitkeep

# Ghidra workspace / generated analysis
ghidra-work/
*.gpr
*.rep
*.rep/
*.gbf
*.sar
*.lock
*.log4j

# Local development notes
dev-notes/*
!dev-notes/README.md